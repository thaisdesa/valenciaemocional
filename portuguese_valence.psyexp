        <Param val="Instruções&amp;#10;&amp;#10;&amp;#10;Na tela seguinte você verá uma palavra e deverá julgá-la na escala de acordo com a forma que você se sente, sendo 01 o mais negativo e 9 o mais positivo.&amp;#10;&amp;#10;&amp;#10;Pressione ESPAÇO para continuar." valType="str" updates="constant" name="text"/>
